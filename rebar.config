{erl_opts, []}.

{project_plugins, [
    erlfmt,
    rebar3_lint,
    rebar3_proper,
    rebar3_ex_doc,
    rebar3_hex,
    coveralls
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{dialyzer, [
    {warnings, [
        unknown,
        unmatched_returns,
        error_handling,
        underspecs
    ]}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.5.0"}
        ]},
        {eunit_opts, [verbose]},
        {cover_enabled, true},
        {cover_opts, [verbose]},
        {extra_src_dirs, ["test"]}
    ]}
]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/erlsci/iso8601">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>}
]}.

%% Formatting configuration for rebar3_format
{format, [
    {files, ["src/*.erl", "include/*.hrl", "test/*.erl", "examples/*.erl"]},
    {formatter, default_formatter},
    {encoding, utf8},
    {paper, 100},
    {ribbon, 90},
    {break_indent, 4},
    {sub_indent, 2}
]}.

{alias, [
    {test, [
        compile,
        eunit
    ]},
    {coverage, [
        {proper, "-c"},
        {cover, "-v --min_coverage=0"}
    ]},
    {check, [
        compile,
        xref,
        dialyzer,
        eunit,
        coverage
    ]}
]}.
